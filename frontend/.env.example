# URL de la API para conectar con el backend
# Reemplaza <TU-IP> con la IP de tu máquina en la red local
# Ejemplo: EXPO_PUBLIC_API_URL=http://192.168.1.100:4000/api

# Para emulador Android usar: http://10.0.2.2:4000/api
# Para dispositivo físico usar: http://<TU-IP-LAN>:4000/api
# Para iOS simulador o web usar: http://localhost:4000/api

EXPO_PUBLIC_API_URL=http://<TU-IP>:4000/api